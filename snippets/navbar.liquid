<nav class="navbar navbar-expand-lg navbar-light bg-light">
    <div class="container">
        <a class="navbar-brand" href="#">
            <img src="{{section.settings.logo | img_url:'master' }}" alt=""
                width="{{section.settings.logo_max_width}}px">
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
            aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav mr-auto">
                {% for link in linklists[section.settings.menu].links %}
                {% if link.links != blank %}
                <li class="nav-item dropdown">
                    <a href="{{ link.url }}" class="nav-link dropdown-toggle" role="button" data-bs-toggle="dropdown"
                        aria-haspopup="true" aria-expanded="false">
                        
                        {{ link.title }}
                    </a>
                    <div class="dropdown-menu" aria-labelledby="navbarDropdown">
                        <div style="display: flex;">
                          {% for childlink in link.links %}
  <a href="{{ childlink.url }}" class="dropdown-item">
    <ul style="list-style-type: none;">
      {% if childlink.object_type == 'collection' %}
        {% assign selected_collection_id = settings.collection_link %}
        {% assign collection = collections[selected_collection_id] %}
        {% if collection %}
          <li>
             <img src="{{ collection.image |  img_url: 'master'}}" alt="{{ collection.title }}">
          </li>
          <li style="text-align: center;">{{ collection.title }}</li>
        {% endif %}
      {% else %}
        <li>
          <img src="{{ childlink.image |  img_url: 'master'}}" alt="{{ childlink.title }}">
        </li>
        <li style="text-align: center;">{{ childlink.title }}</li>
      {% endif %}
    </ul>
  </a>
{% endfor %}

                        </div>
                    </div>
                </li>
                {% else %}
                <li class="nav-item">
                    <a href="{{ link.url }}" class="nav-link">
                        {{ link.title }}
                    </a>
                </li>
                {% endif %}
                {% endfor %}
            </ul>


            <ul class="navbar-nav">
                <li class="nav-item dropdown mini-cart">
                    <a class="nav-link dropdown-toggle" href="#" role="button" id="navbarDropdown"
                        data-bs-toggle="dropdown" aria-expanded="false">
                        Cart
                    </a>
                    
                </li>
            </ul>
        </div>
    </div>

</nav>