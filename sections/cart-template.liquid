<div class="container">
  {% if cart.item_count > 0 %}
    <h1 class="my-4">Shopping Cart</h1>

    <form action="/cart" method="post" class="cart-form" novalidate>
      <div class="row">
        <div class="col-md-8">
            <table class="table table-borderless responsive-table">
                <thead class="small--hide">
                  <tr class="border-bottom">
                    <th>{{ 'general.cart.label.product' | t }}</th>
                    <th>{{ 'general.cart.label.price' | t }}</th>
                    <th>{{ 'general.cart.label.quantity' | t }}</th>
                    <th>{{ 'general.cart.label.total' | t }}</th>
                  </tr>
                </thead>
                <tbody>

                  <!-- if cart has loaded and has items -->
                  <template v-if="cart">
                        <template v-for="(item, index) in cart.items">
                        {% comment %}
            
                        Cart Item Template
                        =====================
                        The data-label attributes on <td> elements are mobile-friendly
                        helpers used for responsive-table labels
                        {% endcomment %}
                          <tr class="responsive-table-row py-2">
                            <td data-label="Product">
                                <div class="d-flex">
                                    <div class="img">
                                      <template v-if="item.image">
                                          <a :href="item.url">
                                            <img class="img-fluid mr-4" width="150" :src="item.image" alt="">
                                          </a>
                                      </template>
                                    </div>
                                    <div class="title">
                                            <a :href="item.url">${ item.product_title }</a>
                                            <template v-if="!item.product_has_only_default_variant">
                                              <p>${ item.variant_title }</p>
                                            </template>
                                            <template v-if="item.properties">
                                                <template v-for="p in item.properties">
                                                      <template  v-if="p.first">
                                                            ${ p.first}
                                                            <template v-if="p.last.includes('/uploads/')">
                                                                <a :href="p.last"> ${p.last.split('/').pop()} </a>
                                                            </template>
                                                            <template v-else>
                                                                ${p.last}
                                                            </template>
                                                      </template>
                                                </template>
                                            </template> <!-- endif item.properties -->                                            
                                    </div>  <!-- title -->
                                </div>
                            </td>
                            <td data-label="Price">
                              <template v-if="item.original_line_price != item.line_price">
                                <span class="visually-hidden">Discounted price</span>
                                  ${ item.price | money }
                                <span class="visually-hidden">Original price</span>
                                <s>${ item.original_price | money }</s>
                              </template>
                              <template v-else>
                                    ${item.price | money }
                              </template>
                            </td>
                            <td data-label="Quantity">
                              <input type="number"
                                    class="form-control"
                                    name="updates[]"
                                    :id="'updates_'+item.key"
                                    v-model="item.quantity"
                                    min="0"
                                    aria-label="Item quantity">
                            </td>
                            <td data-label="Total">
                              ${ total_price(item) | money }
                            </td>
                          </tr>
            
                        </template>

                  </template>


                </tbody>
      
            </table>
        </div>

        <div class="col-md-4">
          <div class="cart-sidebar">
              {% if settings.cart_notes_enable %}
                  <label class="form-label" for="CartSpecialInstructions">Special instructions for seller</label>
                  <textarea class="form-control" name="note" id="CartSpecialInstructions">{{ cart.note }}</textarea>
              {% endif %}
        
                <p>Subtotal</p>
                <p v-if='cart'>${ cart_total_price | money }</p>
                {% if cart.total_discounts > 0 %}
                  <p>You're saving {{ cart.total_discounts | money }}</p>
                {% endif %}
                <p>Shipping & taxes calculated at checkout</p>
                <input type="button" @click="updateCart" name="update" class="btn btn-success" value="Update Cart">
                <input type="submit" name="checkout" class="btn btn-primary" class="button" value="Check Out">

          </div>
        </div>
      </div>

    </form>
  {% else %}

  <h1>Shopping Cart</h1>

  {% comment %}
  Cart empty state
  {% endcomment %}
  <div class="supports-cookies">
    <p>Your cart is currently empty.</p>
    <p>{{ 'cart.general.continue_browsing_html' | t }}</p>
  </div>

  {% comment %}
  Cart no cookies state
  ---------------------
  Browser cookies are required to use the cart. If cookies aren't enabled in the
  browser a message is displayed prompting the user to enable them.
  {% endcomment %}
  <div class="supports-no-cookies">
    <p>Enable cookies to use the shopping cart</p>
  </div>


{% endif %}

</div>